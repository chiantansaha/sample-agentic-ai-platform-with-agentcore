# =====================================================
# Terraform Variables Example - Dev Environment
# =====================================================
# 이 파일을 terraform.tfvars로 복사 후 값을 수정하세요:
#   cp terraform.tfvars.example terraform.tfvars
#
# 주의: terraform.tfvars는 .gitignore에 포함되어 있어
#       git에 커밋되지 않습니다 (민감 정보 보호)
# =====================================================

# -----------------------------------------------------
# AWS Configuration (필수)
# -----------------------------------------------------
# AWS CLI Profile 이름 (aws configure list-profiles로 확인)
aws_profile = "your-aws-profile"

# AWS Region (예: us-east-1, us-west-2, ap-northeast-2)
aws_region  = "us-east-1"

# -----------------------------------------------------
# Project Configuration (필수)
# -----------------------------------------------------
# Base 프로젝트명 - CI/CD에서 사용 (환경 접미사 미포함)
# 예: "agentic-ai", "my-team-ai", "company-aap"
base_project_name = "agentic-ai"

# 실제 프로젝트명 - 모든 리소스 이름의 접두사로 사용됨
# 형식: {base_project_name}-{environment}
# 예: "agentic-ai-dev", "my-team-ai-dev"
# 주의: 다른 프로젝트/팀과 충돌하지 않는 고유한 이름 사용!
project_name = "agentic-ai-dev"

# 환경 (태그용 - 리소스 이름에는 사용 안됨)
environment  = "dev"

# -----------------------------------------------------
# Local Development (선택)
# -----------------------------------------------------
# AWS SSO 사용 시 빈 문자열로 설정
# IAM User 사용 시 사용자 이름 입력
local_dev_user = ""
