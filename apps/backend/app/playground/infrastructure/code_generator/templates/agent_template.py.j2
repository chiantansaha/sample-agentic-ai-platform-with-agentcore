import sys
import contextvars
import types

# Create a complete OpenTelemetry context implementation
class _ContextKey:
    """Simple context key implementation."""
    __slots__ = ("name",)
    def __init__(self, name):
        self.name = name
    def __repr__(self):
        return f"_ContextKey({self.name!r})"

class _Context(dict):
    """Simple context implementation as a dict."""
    pass

_DEFAULT_CONTEXT = _Context()
_CONTEXT_KEY = contextvars.ContextVar("otel_context", default=_DEFAULT_CONTEXT)

def _create_key(name):
    """Create a new context key."""
    return _ContextKey(name)

def _get_value(key, context=None):
    """Get a value from the context."""
    ctx = context if context is not None else _CONTEXT_KEY.get()
    if ctx is None:
        return None
    return ctx.get(key)

def _set_value(key, value, context=None):
    """Set a value in a new context."""
    ctx = context if context is not None else _CONTEXT_KEY.get()
    new_ctx = _Context(ctx) if ctx else _Context()
    new_ctx[key] = value
    return new_ctx

def _get_current():
    """Get the current context."""
    return _CONTEXT_KEY.get()

def _attach(ctx):
    """Attach a context."""
    return _CONTEXT_KEY.set(ctx)

def _detach(token):
    """Detach a context using the token."""
    _CONTEXT_KEY.reset(token)

# Create fake opentelemetry.context module
_fake_context = types.ModuleType("opentelemetry.context")
_fake_context._RUNTIME_CONTEXT = None  # Not needed with this approach
_fake_context.create_key = _create_key
_fake_context.get_value = _get_value
_fake_context.set_value = _set_value
_fake_context.get_current = _get_current
_fake_context.attach = _attach
_fake_context.detach = _detach
_fake_context.Context = _Context

# Also create parent module if needed
if "opentelemetry" not in sys.modules:
    _fake_otel = types.ModuleType("opentelemetry")
    sys.modules["opentelemetry"] = _fake_otel
sys.modules["opentelemetry.context"] = _fake_context
{% endif %}

