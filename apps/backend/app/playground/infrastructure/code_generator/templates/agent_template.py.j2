@app.entrypoint
async def invoke(payload: Dict[str, Any], context: Any = None):
    """Agent invocation endpoint (streaming)

    This is called when POST /invocations is hit.
    Based on: https://docs.aws.amazon.com/bedrock-agentcore/latest/devguide/response-streaming.html

    Args:
        payload: Request payload with:
            - prompt (str): User message (required)
        context: AgentCore runtime context (includes runtimeSessionId)

    Yields:
        Streaming response chunks from the agent
    """
    logger.info(f"Received invocation: {json.dumps(payload)}")

    prompt = payload.get("prompt", "")

    # Get session_id from context or payload
    session_id = None
    if context and hasattr(context, 'session_id'):
        session_id = context.session_id
    elif context and hasattr(context, 'runtime_session_id'):
        session_id = context.runtime_session_id
    elif context and hasattr(context, 'runtimeSessionId'):
        session_id = context.runtimeSessionId

    # Fallback: session_id가 payload에 있을 수도 있음
    if not session_id:
        session_id = payload.get("session_id") or payload.get("runtimeSessionId")

    logger.info(f"Session ID: {session_id} (from {'context' if session_id and context else 'payload or None'})")

    if not prompt:
        yield ({"type": "error", "content": "prompt is required"})
        return

    try:
        # Get or create agent
        agent = get_or_create_agent(session_id)

        # Stream response from agent (AWS docs pattern)
        stream = agent.stream_async(prompt)
        async for event in stream:
            logger.debug(f"Streaming event: {event}")
            yield (event)

    except Exception as e:
        logger.error(f"Agent invocation error: {e}", exc_info=True)
        yield ({"type": "error", "content": str(e)})


