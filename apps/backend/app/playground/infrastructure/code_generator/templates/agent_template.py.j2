# MCP Server Clients
# Note: MCPClient implements ToolProvider interface for automatic lifecycle management
# MCP clients are loaded lazily to handle connection failures gracefully
_mcp_clients = []

def _init_mcp_clients():
    """Initialize MCP clients with error handling for connection failures"""
    clients = []
{% for server in mcp_servers %}
    try:
{% if server.transport == 'http' %}
{% if server.auth_type == 'iam' %}
        # AWS IAM authenticated MCP client (uses Runtime's IAM role)
        # Note: prefix removed to keep tool names short (Bedrock 64 char limit)
        _mcp_{{ server.name }} = MCPClient(
            lambda: aws_iam_streamablehttp_client(
                endpoint="{{ server.url }}",
                aws_region=os.environ.get("AWS_REGION", "{{ server.aws_region | default(aws_region) }}"),
                aws_service="bedrock-agentcore"
            )
        )
{% else %}
        # Standard HTTP MCP client (OAuth/API Key via headers)
        # Note: prefix removed to keep tool names short (Bedrock 64 char limit)
        _mcp_{{ server.name }} = MCPClient(
            lambda: streamablehttp_client(
                url="{{ server.url }}"{% if server.headers %},
                headers={{ server.headers }}{% endif %}
            )
        )
{% endif %}
{% elif server.transport == 'sse' %}
        # Note: prefix removed to keep tool names short (Bedrock 64 char limit)
        _mcp_{{ server.name }} = MCPClient(
            lambda: sse_client("{{ server.url }}")
        )
{% elif server.transport == 'stdio' %}
        # Note: prefix removed to keep tool names short (Bedrock 64 char limit)
        _mcp_{{ server.name }} = MCPClient(
            lambda: stdio_client(
                StdioServerParameters(
                    command="{{ server.command }}",
                    args={{ server.args | default([]) }}
                )
            )
        )
{% endif %}
        # Start the MCP client to establish connection
        _mcp_{{ server.name }}.start()
        clients.append(_mcp_{{ server.name }})
        logger.info("MCP client initialized and started: {{ server.name }}")
        # Debug: Check if tools are available
        try:
            tools = _mcp_{{ server.name }}.list_tools_sync()
            tool_count = len(tools) if tools else 0
            tool_names = [t.tool_name for t in tools] if tools else []
            logger.info(f"MCP '{{ server.name }}' tools loaded: {tool_count} tools - {tool_names}")
        except Exception as tool_err:
            logger.warning(f"Failed to list tools for '{{ server.name }}': {tool_err}")
    except Exception as e:
        logger.error(f"Failed to initialize MCP client '{{ server.name }}': {e}", exc_info=True)
{% endfor %}
    return clients

# Initialize MCP clients (failures are logged but don't stop agent creation)
try:
    _mcp_clients = _init_mcp_clients()
except Exception as e:
    logger.warning(f"Error during MCP client initialization: {e}")
    _mcp_clients = []
