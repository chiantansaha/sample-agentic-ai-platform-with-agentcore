# =============================================================================
# sanitize_mcp_tool_spec - Bedrock Converse API 호환성을 위한 tool_spec 수정
# =============================================================================
_VALID_KEY_PATTERN = re.compile(r'^[a-zA-Z0-9_.-]+$')

def _sanitize_key(key: str) -> str:
    """^[a-zA-Z0-9_.-]{1,64} 패턴에 맞게 변환"""
    if _VALID_KEY_PATTERN.match(key) and len(key) <= 64:
        return key
    return re.sub(r'[^a-zA-Z0-9_.-]', '_', str(key))[:64]

def _sanitize_schema(schema: dict, tool_name: str) -> dict:
    """JSON Schema의 properties 키를 sanitize"""
    if not isinstance(schema, dict):
        return schema

    # Deep copy로 완전히 독립적인 스키마 생성
    result = copy.deepcopy(schema)
    if "properties" in result and isinstance(result["properties"], dict):
        sanitized_props = {}
        for prop_key, prop_value in result["properties"].items():
            # 각 property key를 상세히 로깅
            key_str = str(prop_key)
            key_len = len(key_str)
            pattern_match = _VALID_KEY_PATTERN.match(key_str)
            is_valid = pattern_match and key_len <= 64

            logger.info(
                f"[sanitize_mcp_tool] Tool '{tool_name}' property: "
                f"key='{prop_key}' | len={key_len} | pattern_match={bool(pattern_match)} | valid={is_valid}"
            )

            sanitized_key = _sanitize_key(prop_key)
            if sanitized_key != prop_key:
                logger.warning(
                    f"[sanitize_mcp_tool] Tool '{tool_name}' SANITIZED: "
                    f"'{prop_key}' -> '{sanitized_key}'"
                )
            sanitized_props[sanitized_key] = prop_value
        result["properties"] = sanitized_props

        # required 배열도 매핑
        if "required" in result and isinstance(result["required"], list):
            result["required"] = [_sanitize_key(k) for k in result["required"]]

    return result

def sanitize_mcp_tool_spec(mcp_tool):
    """새로운 MCPAgentTool 인스턴스를 sanitized inputSchema로 생성하여 반환

    Bedrock Converse API 제약사항:
    - inputSchema.properties 키가 ^[a-zA-Z0-9_.-]{1,64} 패턴과 일치해야 함

    중요: Gateway prefix ('{target_name}___')는 유지해야 함!
    - Gateway는 이 prefix를 사용하여 tools/call을 올바른 target으로 라우팅
    - prefix를 제거하면 Gateway가 "Unknown tool" 에러 반환

    이 함수는:
    1. inputSchema의 properties 키를 sanitize
    2. 새로운 MCPTool/MCPAgentTool 객체를 생성하여 반환 (도구 이름은 그대로 유지)

    Args:
        mcp_tool: 원본 MCPAgentTool 인스턴스

    Returns:
        MCPAgentTool: sanitized inputSchema를 가진 새 인스턴스 (도구 이름 유지)
    """
    try:
        tool_name = mcp_tool.tool_name
        original_mcp_tool = mcp_tool.mcp_tool  # mcp.types.Tool 객체
        original_name = original_mcp_tool.name  # Gateway prefix 포함된 원본 이름 유지

        logger.info(f"[sanitize_mcp_tool] Tool '{tool_name}' BEFORE: inputSchema={original_mcp_tool.inputSchema}")

        # inputSchema가 없거나 비어있으면 원본 그대로 반환
        if not original_mcp_tool.inputSchema:
            logger.info(f"[sanitize_mcp_tool] Tool '{tool_name}' no inputSchema, returning as-is")
            return mcp_tool

        # inputSchema sanitize (properties 키만 sanitize, 도구 이름은 유지)
        sanitized_input_schema = _sanitize_schema(
            original_mcp_tool.inputSchema,
            tool_name
        )

        logger.info(f"[sanitize_mcp_tool] Tool '{tool_name}' AFTER: inputSchema={sanitized_input_schema}")

        # 새 MCPTool 생성 (원본 이름 유지 + sanitized inputSchema)
        sanitized_mcp_tool = MCPTool(
            name=original_name,  # ⭐ Gateway prefix 유지! (라우팅에 필요)
            title=getattr(original_mcp_tool, 'title', None),
            description=original_mcp_tool.description,
            inputSchema=sanitized_input_schema,  # ⭐ sanitized!
            outputSchema=getattr(original_mcp_tool, 'outputSchema', None),
        )

        # 새 MCPAgentTool 생성 (원본 이름 유지)
        sanitized_agent_tool = MCPAgentTool(
            mcp_tool=sanitized_mcp_tool,
            mcp_client=mcp_tool.mcp_client,
            name_override=original_name,  # ⭐ Gateway prefix 유지!
            timeout=mcp_tool.timeout
        )

        logger.info(f"[sanitize_mcp_tool] Tool '{tool_name}' sanitized (name preserved: '{original_name}')")
        return sanitized_agent_tool

    except Exception as e:
        logger.error(f"[sanitize_mcp_tool] Failed to sanitize tool: {e}", exc_info=True)
        # 에러 시 원본 반환
        return mcp_tool
