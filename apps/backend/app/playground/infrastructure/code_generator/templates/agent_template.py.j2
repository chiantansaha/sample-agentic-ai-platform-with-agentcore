# Agent instance cache
_agent_cache: Dict[str, Agent] = {}


def get_or_create_agent(session_id: str = None) -> Agent:
    """Agent 인스턴스 가져오기 또는 생성"""
    cache_key = session_id or "default"

    if cache_key in _agent_cache:
        return _agent_cache[cache_key]

    # Model
    model = BedrockModel(
        model_id=AGENT_CONFIG["model_id"],
        temperature=AGENT_CONFIG["temperature"],
        max_tokens=AGENT_CONFIG["max_tokens"]
    )

    # Tools Collection
    tools = []

    {% if has_tools %}
    # Add Strands Community Tools
    tools.extend([{{ tools | join(', ') }}])
    {% endif %}

    {% if knowledge_bases %}
    # Add KB tools
    kb_tools = get_kb_tools()
    tools.extend(kb_tools)
    {% endif %}

    {% if mcp_servers %}
    # Add MCP tools (extracted from MCP clients)
    # MCP clients are already started in _init_mcp_clients()
    # Sanitize tool_spec for Bedrock Converse API compatibility
    for mcp_client in _mcp_clients:
        try:
            # Extract individual tools from MCP client
            mcp_tools = mcp_client.list_tools_sync()
            if mcp_tools:
                # Sanitize each tool and create new instances (list comprehension)
                logger.info(f"[MCP] Processing {len(mcp_tools)} tools for sanitization")
                sanitized_tools = [sanitize_mcp_tool_spec(tool) for tool in mcp_tools]

                # 디버깅: 각 도구 로깅
                for idx, tool in enumerate(sanitized_tools):
                    logger.info(f"[MCP] Tool {idx}: {tool.tool_name} (sanitized)")

                tools.extend(sanitized_tools)
                logger.info(f"Added {len(sanitized_tools)} MCP tools (sanitized)")
            else:
                logger.warning(f"MCP client returned no tools")
        except Exception as e:
            logger.warning(f"Failed to get tools from MCP client: {e}")
    {% endif %}

    {% if has_session_manager %}
    # Session Manager
    session_manager = None
    if session_id and SESSION_BUCKET:
        session_manager = S3SessionManager(
            session_id=session_id,
            bucket=SESSION_BUCKET,
            prefix=SESSION_PREFIX
        )
    {% endif %}

    # Create Agent with all loaded tools
    logger.info(f"Creating agent with {len(tools)} tools")
    agent = Agent(
        model=model,
        tools=tools if tools else None,
        system_prompt=AGENT_CONFIG["system_prompt"],
        {% if has_session_manager %}
        session_manager=session_manager
        {% endif %}
    )

    # Log actual tool specs that will be sent to Bedrock
    logger.info("=" * 80)
    logger.info("[BEDROCK] Tool specs that will be sent to LLM:")
    all_tools_config = agent.tool_registry.get_all_tools_config()
    for tool_name, tool_spec in all_tools_config.items():
        logger.info(f"  Tool: {tool_name}")
        input_schema = tool_spec.get("inputSchema", {})
        if "json" in input_schema:
            properties = input_schema["json"].get("properties", {})
            if properties:
                logger.info(f"    Properties: {list(properties.keys())}")
        logger.info(f"    Full inputSchema: {input_schema}")
    logger.info("=" * 80)

    _agent_cache[cache_key] = agent
    return agent


