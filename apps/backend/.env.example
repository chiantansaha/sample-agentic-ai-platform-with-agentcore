# Environment Configuration Example
#
# 이 파일은 환경변수 설정 예시입니다.
#
# 로컬 개발 시:
#   1. 이 파일을 .env.development.local로 복사
#   2. 실제 값으로 수정
#   3. .env.development.local은 Git에 커밋되지 않음 (gitignored)
#
# 실제 배포 환경:
#   1. .env.development에 실제 개발 환경 리소스 설정
#   2. ECS Fargate에서는 IAM Task Role로 AWS 인증 (크레덴셜 불필요)
#   3. 민감한 정보는 AWS Secrets Manager 사용 권장

# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME=Agentic AI Platform
VERSION=0.1.0

# CORS Settings (comma-separated origins)
# Development: Include localhost URLs for local testing
# Production: Only include production domains
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# Authentication Settings
SKIP_AUTH=true

# AWS Settings
# ECS Fargate에서는 IAM Task Role 사용 (크레덴셜 불필요)
# 로컬 개발 시에는 .env.development.local에서 설정
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB Settings
TABLE_PREFIX=agentic-ai
ENVIRONMENT=dev

# DynamoDB Tables (실제 배포 환경 리소스명으로 설정)
DYNAMODB_AGENT_TABLE=
DYNAMODB_KB_TABLE=
DYNAMODB_KB_VERSIONS_TABLE=
DYNAMODB_PLAYGROUND_TABLE=
DYNAMODB_PLAYGROUND_CONVERSATIONS_TABLE=
DYNAMODB_MCP_TABLE=
DYNAMODB_MCP_VERSIONS_TABLE=

# ECR Settings (for Internal MCP Deploy)
ECR_REPOSITORY_NAME=agentic-ai/mcp-server
ECR_REPOSITORY=

# AgentCore Runtime Settings (Required for Playground)
AGENTCORE_CODE_BUCKET=
AGENTCORE_ROLE_ARN=
PLAYGROUND_SESSIONS_BUCKET=
PLAYGROUND_CONVERSATIONS_TABLE=
PLAYGROUND_RUNTIME_ROLE_ARN=

# Playground ECR Settings (Container Deployment)
PLAYGROUND_ECR_REPOSITORY=

# CodeBuild Settings (Required for Playground)
# AWS CodeBuild is the only supported build method
CODEBUILD_PROJECT_NAME=
AGENT_BUILD_SOURCE_BUCKET=

# Custom Base Image (pre-installed common dependencies for faster builds)
BASE_IMAGE_URI=

# Knowledge Base Settings
BEDROCK_KB_ROLE_ARN=
OPENSEARCH_COLLECTION_ENDPOINT=
OPENSEARCH_COLLECTION_ARN=
SQS_KB_CREATION_QUEUE_URL=
LAMBDA_KB_CREATION_ROLE_ARN=
S3_KB_FILES_BUCKET=

# Bedrock Settings
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
EMBEDDING_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.titan-embed-text-v1
